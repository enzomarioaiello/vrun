#!/usr/bin/env bash
# vrun — Verilog workflow helper
# https://github.com/enzomarioaiello/vrun
#
# Usage:
#   vrun sim    [file.v ...]   Compile and simulate
#   vrun wave   [file.vcd]     Open waveform in Surfer
#   vrun synth  [file.v ...]   Synthesize with Yosys
#   vrun clean                 Remove build artefacts
#   vrun all    [file.v ...]   Run sim → wave → synth
#   vrun doctor                Check dependencies are installed

set -euo pipefail

VRUN_VERSION="0.1.0"

# ── colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}[vrun]${RESET} $*"; }
success() { echo -e "${GREEN}[vrun] ✓${RESET} $*"; }
warn()    { echo -e "${YELLOW}[vrun] ⚠${RESET} $*"; }
error()   { echo -e "${RED}[vrun] ✗${RESET} $*" >&2; exit 1; }

# ── config ────────────────────────────────────────────────────────────────────
# Precedence: env var > .vrun file (walking up from cwd) > built-in default
load_vrun_config() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.vrun" ]]; then
      local line key val
      while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" != *"="* ]] && continue
        key="${line%%=*}"
        val="${line#*=}"
        key="${key#"${key%%[![:space:]]*}"}"; key="${key%"${key##*[![:space:]]}"}"
        val="${val#"${val%%[![:space:]]*}"}"; val="${val%"${val##*[![:space:]]}"}"
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        case "$key" in
          SIM_OUT|VCD|SYNTH_OUT|TOP_MODULE)
            # shellcheck disable=SC2163
            export "VRUN_CFG_$key=$val" ;;
        esac
      done < "$dir/.vrun"
      VRUN_CONFIG_FILE="$dir/.vrun"
      return
    fi
    dir="$(dirname "$dir")"
  done
}

load_vrun_config

SIM_OUT="${VRUN_SIM_OUT:-${VRUN_CFG_SIM_OUT:-sim_out}}"
VCD_FILE="${VRUN_VCD:-${VRUN_CFG_VCD:-wave.vcd}}"
SYNTH_OUT="${VRUN_SYNTH_OUT:-${VRUN_CFG_SYNTH_OUT:-synth_out.v}}"
TOP_MODULE="${VRUN_TOP_MODULE:-${VRUN_CFG_TOP_MODULE:-}}"

# ── helpers ───────────────────────────────────────────────────────────────────
require() {
  command -v "$1" &>/dev/null || error "'$1' not found. Install with: $2"
}

# Portable alternative to mapfile — works on bash 3.x (macOS default)
read_files_into_array() {
  local arr_name="$1"
  local pattern="$2"
  local exclude="${3:-}"
  local _arr=()

  while IFS= read -r -d '' f; do
    _arr+=("$f")
  done < <(find . -maxdepth 2 -name "$pattern" ${exclude:+-not -name "$exclude"} -print0 | sort -z)

  eval "$arr_name=(\"\${_arr[@]}\")"
}

collect_v_files() {
  DESIGN_FILES=()
  TB_FILES=()
  for f in "$@"; do
    local base
    base=$(basename "$f")
    if [[ "$base" == tb_* || "$base" == *_tb.v ]]; then
      TB_FILES+=("$f")
    else
      DESIGN_FILES+=("$f")
    fi
  done
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_sim() {
  require iverilog "brew install icarus-verilog"
  require vvp      "brew install icarus-verilog"

  local V_FILES=()

  if [[ $# -gt 0 ]]; then
    V_FILES=("$@")
  else
    while IFS= read -r -d '' f; do
      V_FILES+=("$f")
    done < <(find . -maxdepth 2 -name "*.v" \
              -not -path "./build/*" \
              -not -name "$(basename "$SYNTH_OUT")" \
              -print0 | sort -z)
    [[ ${#V_FILES[@]} -eq 0 ]] && error "No .v files found in current directory"
  fi

  collect_v_files "${V_FILES[@]}"

  info "Compiling ${#V_FILES[@]} file(s)..."
  for f in "${V_FILES[@]}"; do echo "  → $f"; done

  mkdir -p "$(dirname "$SIM_OUT")" "$(dirname "$VCD_FILE")"

  if iverilog -Wall -g2012 -o "$SIM_OUT" "${V_FILES[@]}" 2>&1; then
    success "Compiled → $SIM_OUT"
  else
    error "Compilation failed"
  fi

  info "Running simulation..."
  echo ""
  vvp "$SIM_OUT"
  echo ""

  if [[ -f "$VCD_FILE" ]]; then
    success "Simulation complete. Waveform written → $VCD_FILE"
    info  "Run 'vrun wave' to open in Surfer"
  else
    success "Simulation complete (no .vcd generated)"
    warn  "Add \$dumpfile/\$dumpvars to your testbench to capture waveforms"
  fi
}

cmd_wave() {
  require surfer "brew install surfer"

  local vcd=""

  if [[ $# -gt 0 ]]; then
    vcd="$1"
  elif [[ -f "$VCD_FILE" ]]; then
    vcd="$VCD_FILE"
  else
    local found=()
    while IFS= read -r -d '' f; do
      found+=("$f")
    done < <(find . -maxdepth 2 -name "*.vcd" -print0 | sort -z)

    if [[ ${#found[@]} -eq 0 ]]; then
      error "No .vcd file found. Run 'vrun sim' first"
    elif [[ ${#found[@]} -eq 1 ]]; then
      vcd="${found[0]}"
    else
      echo -e "${CYAN}Multiple .vcd files found:${RESET}"
      select f in "${found[@]}"; do vcd="$f"; break; done
    fi
  fi

  [[ -f "$vcd" ]] || error "File not found: $vcd"

  # Kill any existing Surfer instance to avoid port conflicts
  if pgrep -f "surfer" &>/dev/null; then
    info "Closing existing Surfer instance..."
    pkill -f "surfer" || true
    sleep 0.5
  fi

  info "Opening $vcd in Surfer..."
  surfer "$vcd" &
  success "Surfer launched"
}

cmd_synth() {
  require yosys "brew install yosys"

  local V_FILES=()

  if [[ $# -gt 0 ]]; then
    V_FILES=("$@")
  else
    while IFS= read -r -d '' f; do
      V_FILES+=("$f")
    done < <(find . -maxdepth 2 -name "*.v" \
              -not -path "./build/*" \
              -not -name "tb_*" \
              -not -name "*_tb.v" \
              -not -name "$(basename "$SYNTH_OUT")" \
              -print0 | sort -z)
    [[ ${#V_FILES[@]} -eq 0 ]] && error "No design .v files found (testbenches excluded)"
  fi

  info "Synthesizing ${#V_FILES[@]} file(s)..."
  for f in "${V_FILES[@]}"; do echo "  → $f"; done

  local read_cmds=""
  for f in "${V_FILES[@]}"; do
    read_cmds+="read_verilog $f; "
  done

  mkdir -p "$(dirname "$SYNTH_OUT")"

  local synth_cmd="synth"
  [[ -n "$TOP_MODULE" ]] && synth_cmd="synth -top $TOP_MODULE"

  if yosys -p "${read_cmds}${synth_cmd}; write_verilog $SYNTH_OUT" 2>&1; then
    success "Synthesis complete → $SYNTH_OUT"
  else
    error "Synthesis failed"
  fi
}

cmd_clean() {
  local removed=0

  for f in "$SIM_OUT" "$VCD_FILE" "$SYNTH_OUT"; do
    if [[ -f "$f" ]]; then
      rm "$f"
      info "Removed $f"
      ((removed++)) || true
    fi
  done

  while IFS= read -r -d '' f; do
    rm "$f"
    info "Removed $f"
    ((removed++)) || true
  done < <(find . -maxdepth 2 -name "*.vcd" -print0 2>/dev/null)

  [[ $removed -eq 0 ]] && info "Nothing to clean" || success "Cleaned $removed file(s)"
}

cmd_all() {
  info "Running full workflow: sim → wave → synth"
  echo ""
  cmd_sim "$@"
  echo ""
  if [[ -f "$VCD_FILE" ]]; then
    cmd_wave
    echo ""
  fi
  cmd_synth "$@"
}

cmd_doctor() {
  echo -e "${BOLD}vrun $VRUN_VERSION — dependency check${RESET}"
  echo ""

  local missing=0
  _doctor_check() {
    local tool="$1" version_cmd="$2" install_hint="$3" required="$4"
    if command -v "$tool" &>/dev/null; then
      local version
      version=$({ eval "$version_cmd" 2>&1 || true; } | awk 'NR==1{ sub(/^[^0-9]*/,""); sub(/[[:space:]]*$/,""); print; exit }')
      [[ -z "$version" ]] && version="installed"
      printf "  ${GREEN}✓${RESET} %-22s %s\n" "$tool" "$version"
    else
      printf "  ${RED}✗${RESET} %-22s not found — %s" "$tool" "$install_hint"
      [[ "$required" == "optional" ]] && printf " ${YELLOW}(optional)${RESET}"
      echo ""
      [[ "$required" != "optional" ]] && ((missing++)) || true
    fi
  }

  _doctor_check iverilog          "iverilog -V"              "brew install icarus-verilog" required
  _doctor_check vvp               "vvp -V"                   "brew install icarus-verilog" required
  _doctor_check yosys             "yosys -V"                 "brew install yosys"          required
  _doctor_check verible-verilog-ls "verible-verilog-ls --version" "brew install verible"   optional
  _doctor_check surfer            "surfer --version"         "brew install surfer"         required
  _doctor_check fswatch           "fswatch --version"        "brew install fswatch"        optional

  echo ""
  if [[ $missing -eq 0 ]]; then
    success "All required dependencies installed"
  else
    error "$missing required dependency(ies) missing"
  fi
}

cmd_version() {
  echo "vrun $VRUN_VERSION"
}

cmd_help() {
  echo -e "${BOLD}vrun $VRUN_VERSION — Verilog workflow helper${RESET}"
  echo ""
  echo -e "${BOLD}Usage:${RESET}"
  echo "  vrun sim    [file.v ...]   Compile and simulate"
  echo "  vrun wave   [file.vcd]     Open waveform in Surfer"
  echo "  vrun synth  [file.v ...]   Synthesize with Yosys"
  echo "  vrun clean                 Remove build artefacts"
  echo "  vrun all    [file.v ...]   Run sim → wave → synth"
  echo "  vrun doctor                Check dependencies are installed"
  echo "  vrun version               Print version"
  echo ""
  echo -e "${BOLD}Project config (.vrun):${RESET}"
  echo "  Drop a .vrun file in the project root to override defaults."
  echo "  Precedence: environment variable > .vrun file > built-in default."
  echo "  Supported keys: SIM_OUT, VCD, SYNTH_OUT, TOP_MODULE"
  echo ""
  echo -e "${BOLD}Environment overrides:${RESET}"
  echo "  VRUN_SIM_OUT     Simulation binary name    (default: sim_out)"
  echo "  VRUN_VCD         VCD waveform filename     (default: wave.vcd)"
  echo "  VRUN_SYNTH_OUT   Synthesis output file     (default: synth_out.v)"
  echo "  VRUN_TOP_MODULE  Top module for synthesis  (default: auto)"
  echo ""
  echo -e "${BOLD}Dependencies:${RESET}"
  echo "  icarus-verilog   brew install icarus-verilog"
  echo "  yosys            brew install yosys"
  echo "  verible          brew install verible"
  echo "  surfer           brew install surfer"
  echo ""
  echo -e "${BOLD}Examples:${RESET}"
  echo "  vrun sim                     # compile all .v files in cwd"
  echo "  vrun sim top.v tb_top.v      # compile specific files"
  echo "  vrun wave                    # open wave.vcd in Surfer"
  echo "  vrun wave dump.vcd           # open a specific .vcd file"
  echo "  vrun synth top.v             # synthesize a specific file"
  echo "  VRUN_VCD=dump.vcd vrun wave  # override the default .vcd name"
}

# ── dispatch ──────────────────────────────────────────────────────────────────
CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  sim)              cmd_sim     "$@" ;;
  wave)             cmd_wave    "$@" ;;
  synth)            cmd_synth   "$@" ;;
  clean)            cmd_clean        ;;
  all)              cmd_all     "$@" ;;
  doctor)           cmd_doctor       ;;
  version|--version) cmd_version    ;;
  help|--help|-h)   cmd_help        ;;
  *) error "Unknown command '$CMD'. Run 'vrun help'" ;;
esac
